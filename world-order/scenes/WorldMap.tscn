offset_top = -2000.0
offset_right = 5000.0
offset_bottom = 3000.0
color = Color(0.027, 0.043, 0.067, 1)
mouse_filter = 2

[node name="Countries" type="Node2D" parent="."]

[node name="MapCamera" type="Camera2D" parent="."]

