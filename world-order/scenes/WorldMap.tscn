[ext_resource type="Script" path="res://scripts/WorldMap.gd" id="1_map"]
[ext_resource type="Script" path="res://scripts/GameOverlay.gd" id="2_overlay"]

[node name="WorldMap" type="Node2D"]
script = ExtResource("1_map")

; ════════════════════ MAPA (background, tela cheia) ════════════════════
[node name="Ocean" type="ColorRect" parent="."]
